# Скопируйте этот файл как .env и заполните свои значения

# Токен бота (получить у @BotFather в Telegram)
BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID вашего Telegram-канала (с @ или числовой ID)
CHANNEL_ID=@bahtresidence

# Ваши Telegram ID (через запятую) — кто может добавлять объекты
# Узнать свой ID: написать @userinfobot в Telegram
ADMIN_IDS=123456789,987654321

# URL вашего сервера (после деплоя на Railway/Render)
MINIAPP_URL=https://ваш-проект.railway.app

# Порт (Railway/Render задают автоматически)
PORT=8080
